{
  "name": "reservas-crm",
  "version": "1.0.0",
  "description": "Self-hosted WhatsApp CRM for customer conversations, AI-assisted replies, and reservation workflows",
  "license": "MIT",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/jespinolas/reservas-crm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jespinolas/reservas-crm.git"
  },
  "bugs": {
    "url": "https://github.com/jespinolas/reservas-crm/issues"
  },
  "keywords": [
    "whatsapp",
    "crm",
    "reservations",
    "ai",
    "self-hosted",
    "nextjs",
    "postgresql"
  ],
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:fresh-install": "bash scripts/fresh-install-smoke.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:demo": "esbuild scripts/seed/demo.ts --bundle --platform=node --format=esm --outfile=.tmp-seed-demo.mjs --alias:@=./src --packages=external && node .tmp-seed-demo.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "better-auth": "^1.1.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "next": "^15.5.21",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "playwright": "^1.61.1",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
